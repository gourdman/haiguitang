# =============================================================================
# 这是「示例模板」：不要在本文件填写真实密钥；若曾误填，请到 DeepSeek 控制台
# 作废该 Key 并重新生成，避免泄露（尤其已用 Git 提交时）。
# =============================================================================
# 正确做法：
# 1. 在项目根目录（与 package.json 同级）新建文件，命名为 `.env` 或 `.env.local`
# 2. 从本文件复制「变量名那一行」过去，把等号后面改成你的真实 Key
# 3. 文件名必须是 `.env` 或 `.env.local`，不要用 .env.example / .env_example ——
#    Vite 不会读取它们来注入 DEEPSEEK_API_KEY，代理也就拿不到密钥。
# 4. 修改后执行：停掉再重新运行 `npm run dev`
#
# 变量名不要使用 VITE_ 前缀（密钥不能进前端打包）。
# =============================================================================

DEEPSEEK_API_KEY=sk-36633d9c44b9462b9db1d89c595ae366

# -----------------------------------------------------------------------------
# 生产环境（可选）：纯静态部署没有 Vite 代理时，需要你自己的后端/边缘函数转发
# DeepSeek，前端只请求你的域名。此处只填「你的 API 网关地址」，仍不要写密钥。
# 示例：https://your-app.vercel.app/api/deepseek
# -----------------------------------------------------------------------------
# VITE_API_PROXY_BASE=https://your-backend.example.com/api/deepseek

# -----------------------------------------------------------------------------
# 可选：覆盖默认模型（默认 deepseek-chat）
# -----------------------------------------------------------------------------
# VITE_DEEPSEEK_MODEL=deepseek-chat
